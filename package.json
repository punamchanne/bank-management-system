{
  "name": "neofin-core-banking",
  "version": "1.0.0",
  "description": "NeoFin Core Banking System - Full Stack Banking Application",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "server": "node server/index.js",
    "server:dev": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "seed": "node server/seed.js",
    "build": "npm run install:all && cd client && npm run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  }
}
